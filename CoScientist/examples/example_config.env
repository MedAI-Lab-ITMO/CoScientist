# =========================
# LLM
# =========================
LLM__SERVICE_KEY=
LLM__OPENAI_API_KEY=

LLM__MAIN_URL=https://openrouter.ai/api/v1
LLM__SCENARIO_URL=https://openrouter.ai/api/v1
# The provider prefix (e.g. "openrouter/") selects the routing/base-URL via
# litellm. Keep it on model ids that should go through OpenRouter, otherwise
# litellm cannot infer the provider and tool-calling may misbehave.
LLM__MAIN_MODEL=openrouter/qwen/qwen3-235b-a22b-2507
LLM__SCENARIO_MODEL=qwen/qwen3-235b-a22b-2507
# Dedicated (optionally stronger) model for the CoderAgent's multi-step tool use.
# Falls back to LLM__MAIN_MODEL when empty.
LLM__CODER_MODEL=

LLM__SERVICE_URL=https://openrouter.ai/api/v1
LLM__SERVICE_CC_URL=https://openrouter.ai/api/v1/chat/completions

LLM__VISION_URL=https://openrouter.ai/api/v1;google/gemini-2.5-flash
LLM__SUMMARY_URL=https://openrouter.ai/api/v1;google/gemini-2.0-flash-lite-001
LLM__MARKER_MODEL=google/gemini-2.0-flash-lite-001
LLM__DATASETS_URL=https://openrouter.ai/api/v1;openai/gpt-5
LLM__DEEPEVAL_URL=https://openrouter.ai/api/v1;openai/gpt-4o-2024-08-06

LLM__ALLOWED_PROVIDERS=["google-vertex", "azure"]


# =========================
# SERVICES APIs
# =========================
SERVICES__TAVILY_API_KEY=
SERVICES__OPENALEX_API_KEY=

# =========================
# STORAGE
# =========================
STORAGE__PARSE_RESULTS=PaperAnalysis/parse_results
STORAGE__CHROMA_STORAGE=PaperAnalysis/chromadb
STORAGE__PAPERS_STORAGE=PaperAnalysis/papers

STORAGE__DS_STORAGE=ChemCoScientist/data_store/datasets
STORAGE__IMG_STORAGE=ChemCoScientist/data_store/imgs
STORAGE__ANOTHER_STORAGE=ChemCoScientist/data_store/another

STORAGE__PATH_TO_DATA=tools/models/datasets/image_dataset_multi_filtered
STORAGE__PATH_TO_CVAE_CHECKPOINT=tools/models/checkpoints/cvae/model.pt
STORAGE__PATH_TO_RESULTS=tools/generation_results
STORAGE__PATH_TO_TEMP_FILES=PaperAnalysis/temp_files
STORAGE__MY_PAPERS=/full/path/to/folder/with/papers/for/paper/assistant

STORAGE__LOGGING_PATH=logs/

STORAGE__UPLOADED_PAPERS=local_papers/

# =========================
# HOSTS & PORTS
# =========================
HOSTS_PORTS__CHROMA_HOST=0.0.0.0
HOSTS_PORTS__EMBEDDING_HOST=0.0.0.0
HOSTS_PORTS__RERANKER_HOST=0.0.0.0
HOSTS_PORTS__OPENCHEMIE_HOST=0.0.0.0
HOSTS_PORTS__RETROSYNTHESIS_SERVICES_HOST=0.0.0.0
HOSTS_PORTS__CHEM_SERVICES_HOST=0.0.0.0

HOSTS_PORTS__CHROMA_PORT=9999
HOSTS_PORTS__EMBEDDING_PORT=9999
HOSTS_PORTS__RERANKER_PORT=9999
HOSTS_PORTS__OPENCHEMIE_PORT=8005
HOSTS_PORTS__RETROSYNTHESIS_SERVICES_PORT=8001
HOSTS_PORTS__CHEM_SERVICES_HOST=0.0.0.0

# =========================
# COLLECTIONS
# =========================
COLLECTIONS__SUMMARIES=your-name-here
COLLECTIONS__TEXTS=your-name-here
COLLECTIONS__IMAGES=your-name-here


# =========================
# S3
# =========================
S3__USE_S3=True
S3__ENDPOINT_URL=http://0.0.0.0:9000
S3__ACCESS_KEY=username
S3__SECRET_KEY=password
S3__BUCKET_NAME=bucket-name


# =========================
# OPIK
# =========================
OPIK__API_KEY=your-api-key
OPIK__URL_OVERRIDE=https://www.comet.com/opik/api
OPIK__PROJECT_NAME=your-project-name


# =========================
# MCP
# =========================
MCP__PAPER_ANALYSIS_URL=
MCP__PAPERS_SEARCH_URL=



# =========================
# RAG tools
# =========================
# Database Configuration
QDRANT__URL=http://host.docker.internal:6333
QDRANT__API_KEY=

POSTGRES__HOST=host.docker.internal
POSTGRES__PORT=5432
POSTGRES__USER=rag_tools
POSTGRES__PASSWORD=rag_tools_password
POSTGRES__DATABASE=rag_tools

# Embedding Configuration
EMBEDDING__MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING__DEVICE=cpu
EMBEDDING__BATCH_SIZE=32

# APIEmbedding Configuration
API_EMBEDDING__URL=http://10.32.1.36:5002/embed
API_EMBEDDING__API_KEY=
API_EMBEDDING__BATCH_NORMALIZE_EMBEDDINGS=False

# Reranker Configuration
RERANKER__MODEL_NAME=cross-encoder/ms-marco-MiniLM-L-6-v2
RERANKER__DEVICE=cpu
RERANKER__BATCH_SIZE=32
RERANKER__TOP_K=20

# APIEmbedding Configuration
API_RERANKER__URL=http://10.32.1.36:5001/rerank
API_EMBEDDING__API_KEY=
API_RERANKER__TOP_K=20

# RAG Configuration
RAG__DEFAULT_TOP_K=10
RAG__RERANK_TOP_K=5
RAG__MIN_RELEVANCE_SCORE=0.3
RAG__CHUNK_SIZE=512
RAG__CHUNK_OVERLAP=50

# Storage
WORK_DIR=/tmp/rag_tools



# =========================
# MED LLM (MedicalAgent backend service)
# =========================
MED_LLM__TASK_URL=
MED_LLM__RESULT_URL=
MED_LLM__LOGIN=
MED_LLM__PASSWORD=
MED_LLM__POLL_INTERVAL=10
MED_LLM__MAX_POLLS=60

# =========================
# HITL (Human-in-the-Loop)
# =========================
# When true, planner/research/task agents pause for console approval. Set false
# for unattended/automated runs (and for A2A, where stdin prompts would hang).
HITL__ENABLED=true

# =========================
# ORCHESTRATOR
# =========================
# When true, the PlannerAgent is attached and called first to build a roadmap.
# When false, the orchestrator plans inline (planner tool not attached).
ORCHESTRATOR__USE_PLANNER=false

# =========================
# CODE EXECUTION (CoderAgent sandbox)
# =========================
# Optional remote code-exec server. When CODE_EXEC__URL is empty the CoderAgent
# runs commands locally in a per-session sandbox under CODE_EXEC__WORKSPACE_ROOT.
CODE_EXEC__URL=
CODE_EXEC__SUBMIT_PATH=/submit
CODE_EXEC__RESULT_PATH=/result
CODE_EXEC__POLL_INTERVAL=5
CODE_EXEC__DEFAULT_TIMEOUT=1800
# execute_bash waits inline up to EXEC_WAIT seconds for the command to finish
# and returns the result directly (so the model doesn't burn turns polling).
# Only jobs that run longer hand back a job_id for check_job.
CODE_EXEC__EXEC_WAIT=180
CODE_EXEC__CHECK_WAIT=15
CODE_EXEC__WORKSPACE_ROOT=./workspace

# =========================
# A2A (Agent-to-Agent servers — see docs/a2a.md)
# =========================
# Host/ports for `python -m CoScientist.a2a.run_all`.
A2A_HOST=localhost
ORCHESTRATOR_PORT=8000
PLANNER_PORT=8001
HYPOTHESES_PORT=8002
RESEARCH_PORT=8003
TASK_EXECUTION_PORT=8004
MEDICAL_PORT=8005
CODER_PORT=8006
# Set to 1 so `adk web` serves the A2A orchestrator (sub-agents must be running).
A2A_MODE=
# Set to 1 to disable Opik tracing on the A2A servers.
A2A_DISABLE_OPIK=
# Pins a single shared CoderAgent sandbox across A2A delegations (the coder
# server defaults this to "a2a_shared"); override to isolate concurrent runs.
CODER_WORKSPACE_ID=

# =========================
# MISCELLANEOUS
# =========================
FEDOTMAS_DEFAULT_MODEL= openrouter/openai/gpt-oss-120b
OPENAI_API_KEY = 
DOWNLOADED_PAPERS_PATH=/full/path/to/folder/for/downloaded/papers
PROCESSED_IMG_STORAGE_PATH=ChemCoScientist/data_store/imgs-proc